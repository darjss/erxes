{
  "name": "car_api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "backend/plugins/car_api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "backend/plugins/car_api",
        "commands": [
          "pnpm build"
        ]
      },
      "dependsOn": [
        "^build"
      ]
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "typecheck",
        "build"
      ],
      "options": {
        "cwd": "backend/plugins/car_api",
        "command": "NODE_ENV=development node dist/src/main.js"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/plugins/car_api",
        "command": "NODE_ENV=development pnpm dev"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/plugins/car_api",
        "command": "pnpm exec jest --config jest.config.ts --runInBand"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint backend/plugins/car_api"
      }
    },
    "docker-build": {
      "dependsOn": [
        "build"
      ],
      "command": "docker build -f backend/plugins/car_api/Dockerfile . -t erxes/erxes-next-car_api"
    }
  }
}

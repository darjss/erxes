# Mastra plugin — environment reference.
#
# erxes loads a single root .env; these keys are documented here (in-plugin) so
# the advanced-memory configuration lives with the feature. Copy the ones you
# need into your root .env.

# --- Advanced memory feature (opt-in; OFF by default) ---
# Enables cross-session semantic recall (Qdrant) + working memory. Must be the
# EXACT value "enable" to turn on; anything else is treated as off. Restart the
# plugin after changing. Requires Qdrant:
#   docker compose -f backend/plugins/erxes-agent_api/docker-compose.yml up -d
# ERXES_AGENT_MEMORY=enable

# Qdrant connection
# ERXES_AGENT_QDRANT_URL=http://localhost:6333
# ERXES_AGENT_QDRANT_API_KEY=

# Embedder: "fastembed" (local, no API key — default) or "openai" (API endpoint)
# ERXES_AGENT_EMBEDDER=fastembed
# ERXES_AGENT_EMBEDDER_MODEL=
# ERXES_AGENT_EMBEDDER_BASE_URL=https://api.openai.com/v1
# ERXES_AGENT_EMBEDDER_API_KEY=

# Semantic-recall tuning (defaults shown)
# ERXES_AGENT_MEMORY_TOPK=4
# ERXES_AGENT_MEMORY_MIN_SCORE=0.5
# ERXES_AGENT_MEMORY_SCOPE=resource

# --- Voice mode (in-chat speech-to-text + text-to-speech) ---
# Powered by Chimege (chimege.com — Mongolian speech AI). Chimege issues a
# SEPARATE token per direction. Each direction turns on when its token is set
# and ERXES_AGENT_VOICE is NOT "disable"; the chat UI shows voice mode only when
# BOTH are configured. No ffmpeg / server transcode is needed — the browser
# captures raw PCM and encodes the WAV itself, which STT relays to Chimege.
# These values are the DEPLOYMENT-WIDE DEFAULT. Each tenant can override the
# tokens + voice from the agent settings UI (per-tenant BYOK); env is the fallback.
# CHIMEGE_STT_TOKEN=
# CHIMEGE_TTS_TOKEN=
# ERXES_AGENT_VOICE=disable
# CHIMEGE_TTS_VOICE=FEMALE4v2   # default; FEMALE1/1v2/2v2/3v2/4v2/5v2, MALE1/1v2/2v2/3v2/4v2
# CHIMEGE_TTS_SAMPLE_RATE=22050 # 8000 | 16000 | 22050
# CHIMEGE_STT_PUNCTUATE=true    # auto-punctuate transcripts
